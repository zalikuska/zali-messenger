# ================================================================
# ZaliMessenger Server — Конфигурация окружения
# Скопируйте в .env и заполните перед запуском в продакшене
# ================================================================

# ОБЯЗАТЕЛЬНО в продакшене: секретный ключ для подписи JWT-токенов.
# Должен быть не менее 32 символов. Сгенерировать: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_ZALI_SECRET_KEY_MIN32CH

# Разрешённые CORS-источники (через запятую).
# В продакшене укажите только ваш домен.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000,http://127.0.0.1,zali://localhost,null

# Максимальный размер загружаемого файла в байтах (по умолчанию 10MB).
MAX_UPLOAD_BYTES=10485760

# Включить гостевой режим: запросы без токена работают как пользователь "Zalikus".
# true — для совместимости с macOS-клиентом без авторизации.
# false — строгий режим (рекомендуется для продакшена).
ALLOW_GUEST_MODE=true

# Rate limiting для /api/auth/login:
# Максимум RATE_LIMIT_MAX_ATTEMPTS попыток за RATE_LIMIT_WINDOW_SECS секунд.
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_MAX_ATTEMPTS=10

# Размер буфера WebSocket-канала на пользователя (bounded channel).
# При переполнении новые сообщения отбрасываются с предупреждением.
WS_CHANNEL_CAPACITY=64

# Уровень логирования (tracing).
# Варианты: error, warn, info, debug, trace
RUST_LOG=zali_server=info,tower_http=warn

# Web Push (VAPID) для браузерного/PWA клиента — доставка уведомлений, когда
# вкладка/PWA полностью закрыта (не нужно для macOS/Windows/iOS/Android — у них
# своя локальная SHOW_NOTIFICATION). Если пусто — фича отключена:
# /api/push/vapid-public-key вернёт 404, клиент не будет подписываться.
# Сгенерировать новую пару: cargo run --manifest-path server/Cargo.toml --example gen_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@zalikus.org

# Токен для публикации релизов macOS/Windows-клиента (POST /api/version).
# Если пусто — POST /api/version всегда 403, фича автообновления отключена.
# GET /api/version (проверка обновлений клиентами) публичный и не требует токена.
RELEASE_ADMIN_TOKEN=
